# Python
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Environment
.env
.env.*

# Logs (generated at runtime)
logs/*
!logs/.gitkeep
models/*/logs/*.log
models/*/metrics/*.db

# Model assets (never commit large binary files or bundled docs)`r`nmodels/**/*.gguf`r`nmodels/**/*.safetensors`r`nmodels/**/*.bin`r`nmodels/**/*.pt`r`nmodels/**/*.pth`r`nmodels/**/*.ckpt`r`nmodels/*.md`r`nmodels/*/model.README.md`r`nmodels/*/weights/*.md`r`nmodels/*/vision/*.md

# Checksums are committed (small, important)
# models/*/weights/*.sha256  ← do NOT ignore these

# Runtime data
data/*.pid
data/server.state.json

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS
Thumbs.db
desktop.ini
.DS_Store

# llama.cpp binaries (too large, install separately)`r`nbin/*.exe`r`nbin/*.dll`r`n!bin/version.txt

