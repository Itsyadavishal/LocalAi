# Python
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Environment
.env
.env.*

# Logs (generated at runtime)
logs/*
!logs/.gitkeep
models/*/logs/*.log
models/*/metrics/*.db

# Model assets (never commit large binary files or bundled docs)
models/**/*.gguf
models/**/*.safetensors
models/**/*.bin
models/**/*.pt
models/**/*.pth
models/**/*.ckpt
models/*.md
models/*/model.README.md
models/*/weights/*.md
models/*/vision/*.md

# Checksums are committed (small, important)
# models/*/weights/*.sha256  <- do NOT ignore these

# Runtime data
data/*.pid
data/server.state.json

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS
Thumbs.db
desktop.ini
.DS_Store

# llama.cpp binaries (too large, install separately)
bin/*.exe
bin/*.dll
!bin/version.txt
